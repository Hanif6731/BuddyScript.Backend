# BuddyScript Backend .env Template
# Copy this file to '.env' and fill in the actual values.

# Database Configuration
ConnectionStrings__DefaultConnection=Server=localhost,1433;Database=BuddyScript;User Id=sa;Password=sa@123;TrustServerCertificate=True;

# JWT Authentication
Jwt__Key=this-is-a-very-long-secret-key-for-buddyscript
Jwt__Issuer=BuddyScript.Backend
Jwt__Audience=BuddyScript.Client
# Optional: Set the auth cookie name (Default: buddyscript_auth)
Jwt__CookieName=buddyscript_auth

# Google OAuth2 Credentials
Google__ClientId=your_google_client_id_here
Google__ClientSecret=your_google_client_secret_here
